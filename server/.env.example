# Railmate Server Environment Configuration

# Server
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=railmate
POSTGRES_USER=railmate
POSTGRES_PASSWORD=railmate

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# API Tokens (optional - for secondary data sources)
SNCF_API_TOKEN=
NATIONAL_RAIL_API_TOKEN=
